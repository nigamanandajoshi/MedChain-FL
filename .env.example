# =============================================================================
# MedChain-FL Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For local Hardhat testing: use the pre-funded test accounts below (publicly
# known keys — safe ONLY on the local devnet, never on a live network).
# For staging / production: use keys from a proper HSM or secrets manager.
# =============================================================================

# --- Ethereum Node ---
ETH_RPC_URL=http://127.0.0.1:8545

# --- Admin (Server) Key ---
# Hardhat Account #0 — replace with a real key for staging/production
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- Hospital Client Keys ---
# Hardhat Accounts #1-#3 — replace with real keys for staging/production
HOSPITAL_ITALY_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
HOSPITAL_PAKISTAN_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
HOSPITAL_USA_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# --- Contract Addresses (auto-populated by start_blockchain.sh) ---
# You can also set these manually after deploying.
GOVERNANCE_CONTRACT_ADDRESS=
LEDGER_CONTRACT_ADDRESS=
